# ============================================================
# BeatChain — Blockchain Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ============================================================

# Sepolia RPC endpoint — get one free at https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private key of the wallet used to deploy contracts.
# Must have Sepolia ETH. Get test ETH at https://sepoliafaucet.com
# Include the 0x prefix.
SEPOLIA_PRIVATE_KEY=0xYOUR_DEPLOYER_WALLET_PRIVATE_KEY
